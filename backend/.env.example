# متغيرات بيئة التطوير - Backend
# انسخ هذا الملف إلى .env وعدّل القيم قبل التشغيل

# ==========================================
# إعدادات الخادم
# ==========================================
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# ==========================================
# قاعدة البيانات
# ==========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=yatama_db
DB_USER=root
DB_PASS=YourStrongPasswordHere

# Prisma
DATABASE_URL="mysql://root:YourStrongPasswordHere@localhost:3306/yatama_db"

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=your-very-long-and-secure-jwt-secret-key-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_REFRESH_EXPIRES_IN=30d

# ==========================================
# AWS S3 (رفع الملفات والصور)
# ==========================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=me-south-1
AWS_S3_BUCKET=yatama-charity-files

# ==========================================
# Stripe (بوابة الدفع)
# ==========================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-public-key

# ==========================================
# البريد الإلكتروني (SendGrid)
# ==========================================
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=info@yatama-charity.org
EMAIL_FROM_NAME=مؤسسة اليتامى الخيرية

# ==========================================
# WhatsApp Business API
# ==========================================
WHATSAPP_TOKEN=your-whatsapp-business-token
WHATSAPP_PHONE_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-verify-token

# ==========================================
# الواجهة الأمامية (للـ CORS)
# ==========================================
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ==========================================
# الأمان
# ==========================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
